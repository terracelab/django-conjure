{
  "name": "django-conjure-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for Conjure — conjure your Django admin.",
  "homepage": "https://conjure.terracelab.co.kr",
  "repository": {
    "type": "git",
    "url": "https://github.com/terracelab/django-conjure"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "web:build": "pnpm --filter conjure-admin build",
    "web:typecheck": "pnpm --filter conjure-admin typecheck",
    "landing:dev": "pnpm --filter conjure-landing dev",
    "landing:build": "pnpm --filter conjure-landing build"
  }
}
