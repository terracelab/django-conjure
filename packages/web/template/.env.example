# Conjure web env reference. Put real values in .env.local (gitignored).
# Restart the vite dev server after changing any value (env is loaded once at boot).

# API base path. Defaults to /conjure (matches the conjure.urls mount in Django).
# Override if you mounted conjure.urls under a different prefix.
VITE_API_BASE=/conjure

# Dev proxy target (local Django backend). Defaults to http://localhost:8000.
VITE_PROXY_TARGET=http://localhost:8000

# Production build: absolute API base URL when the backend is a different origin.
# In dev the proxy handles this, so it is unnecessary there.
# VITE_API_BASE_URL=https://api.example.com

# ── Theme color overrides ──
# ⚠️ hex values MUST be quoted: "#4f46e5"  (the .env parser treats an unquoted # as a comment)
#    "R G B" channel values are also accepted. Unset tokens fall back to src/index.css. Applied by src/lib/theme.ts.
# Restart the vite dev server completely after changing values.
VITE_COLOR_ACCENT="#4f46e5"
# VITE_COLOR_ACCENT_HOVER="#4338ca"   # if unset, derived automatically from accent
# VITE_COLOR_SIDEBAR="#0b0b0f"
# VITE_COLOR_SIDEBAR_HOVER="#3f3f46"
# VITE_COLOR_SUCCESS="#16a34a"
# VITE_COLOR_WARNING="#d97706"
# VITE_COLOR_DANGER="#dc2626"
# VITE_COLOR_INFO="#2563eb"
# VITE_COLOR_GAIN="#dc2626"
# VITE_COLOR_LOSS="#2563eb"
