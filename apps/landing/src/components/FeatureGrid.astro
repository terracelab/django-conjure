---
// Feature grid — sourced from PACKAGE_GUIDE §12 implementation-status table.
const features = [
  {
    title: "Introspection → CRUD",
    body: "Reads model metadata — fields, types, choices, FKs, permissions — and serves it as JSON for codegen and runtime alike.",
  },
  {
    title: "Generic CRUD, bulk & autocomplete",
    body: "One generic ViewSet: list, retrieve, create, update, delete, plus server-side search, filter, sort, pagination, atomic bulk and autocomplete.",
  },
  {
    title: "Audit log",
    body: "Every write is recorded with a field-level diff. One migration adds the audit table; your own models are never touched.",
  },
  {
    title: "Staff auth",
    body: "Session or JWT login gated on is_staff. Reuse the Django session you already have, or issue staff tokens.",
  },
  {
    title: "Dashboard widgets",
    body: "Stats, trends and recent-activity cards from a widget registry. Register your own with a backend hook and a frontend component.",
  },
  {
    title: "Codegen + runtime",
    body: "Eject pages to plain .tsx you own, or render models at runtime from the schema. Hybrid by design — choose per model.",
  },
  {
    title: "Theming via tokens",
    body: "Accent and surface colors come from shared CSS tokens — the same ones this site uses. Re-theme without code changes.",
  },
  {
    title: "Actions & permissions",
    body: "Per-(action × model) spells — export, refund, issue invoice — gated by Django Groups. Synced without migrations.",
    soon: true,
  },
];
---

<section id="features" class="container-page py-20 sm:py-24" aria-labelledby="features-heading">
  <div class="max-w-2xl">
    <p class="eyebrow">Features</p>
    <h2 id="features-heading" class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
      Everything an admin needs, summoned from your models
    </h2>
    <p class="mt-4 text-fg-muted">
      Production-grade pieces — not a toy scaffold. Read your schema once, get the
      whole surface area.
    </p>
  </div>

  <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      features.map((f) => (
        <li class="card flex flex-col gap-2">
          <div class="flex items-center gap-2">
            <h3 class="text-base font-semibold">{f.title}</h3>
            {f.soon && (
              <span class="rounded-token bg-warning/12 px-2 py-0.5 text-[11px] font-medium uppercase tracking-wide text-warning">
                Coming soon
              </span>
            )}
          </div>
          <p class="text-sm leading-relaxed text-fg-muted">{f.body}</p>
        </li>
      ))
    }
  </ul>
</section>
