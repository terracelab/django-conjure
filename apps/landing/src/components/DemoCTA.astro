---
// Live-demo CTA. The read-only demo is built from examples/demo-shop and
// deployed with a seeded, read-only DB.
// TODO(wiring): point `demoUrl` at the deployed demo once examples/demo-shop is
// published (planned: conjure.terracelab.dev/demo). Until then it links to docs.
const demoUrl = "https://conjure.terracelab.dev"; // placeholder → swap for /demo
const repo = "https://github.com/terracelab/django-conjure";
const demoLive = false; // flip to true when the live demo is wired
---

<section id="demo" class="container-page py-20 sm:py-24" aria-labelledby="demo-heading">
  <div
    class="surface-dark relative isolate overflow-hidden rounded-token border border-line px-6 py-14 text-center sm:px-12"
  >
    <div
      class="pointer-events-none absolute inset-0 -z-10 flex items-center justify-center"
      aria-hidden="true"
    >
      <div class="h-72 w-72 rounded-full bg-brand-500/25 blur-[100px]"></div>
    </div>

    <p class="eyebrow text-brand-400">Live demo</p>
    <h2 id="demo-heading" class="mx-auto mt-3 max-w-2xl text-3xl font-semibold tracking-tight sm:text-4xl">
      Click through a real admin
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-fg-muted">
      A read-only Conjure admin built from the <code class="font-mono text-brand-400">examples/demo-shop</code>
      project, seeded with sample data. Browse, filter, and inspect — no signup.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href={demoUrl}
        class="btn-primary text-base"
        aria-disabled={!demoLive}
      >
        {demoLive ? "Open live demo" : "Live demo — coming soon"}
      </a>
      <a href={repo} class="btn-ghost text-base" rel="noopener">View the source</a>
    </div>

    {
      !demoLive && (
        <p class="mt-4 text-xs text-fg-muted">
          The hosted demo is wired up after <code class="font-mono">examples/demo-shop</code> ships.
        </p>
      )
    }
  </div>
</section>
